# AWG-PORTAL configuration sample
# Полная документация: https://wgportal.org/master/documentation/overview/
#
# Все параметры можно задать через переменные окружения:
#   WG_PORTAL_<SECTION>_<KEY>
# Пример: advanced.log_level → WG_PORTAL_ADVANCED_LOG_LEVEL

advanced:
  log_level: info
  # Путь для сохранения wg-конфигов на диск (save-config).
  # Без этого параметра save-config не работает и возвращает ошибку.
  # config_storage_path: /app/config

core:
  admin_user: admin@example.com
  admin_password: CHANGE_ME_PLEASE
  restore_state: false
  import_existing: false
  create_default_peer_on_login: false
  create_default_peer_on_user_creation: false
  create_default_peer_on_interface_creation: false

web:
  external_url: http://localhost:8888
  request_logging: true
  listening_address: ":8888"
  site_title: "AWG-PORTAL"
  site_company_name: "AWG-PORTAL"

database:
  type: sqlite
  dsn: data/sqlite.db

auth:
  # WebAuthn (Passkey) — включите, если настроен HTTPS с доверенным сертификатом.
  # RPID (Relaying Party ID) определяется из web.external_url.
  # Без HTTPS использовать не будет.
  webauthn:
    enabled: false

backend:
  default: local
  # AmneziaWG integration mode (local backend only):
  #   auto   - try amneziawg-go, fallback to kernel WG (default)
  #   always - require amneziawg-go, error if not available
  #   never  - kernel WG only, ignore AWG parameters
  awg_mode: auto
