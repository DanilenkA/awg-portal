# AWG-PORTAL configuration sample
#
# ──────────────────────────────────────────────────────────────────────
# ESSENTIAL — change these before starting the service
# ──────────────────────────────────────────────────────────────────────
#  - core.admin_user / core.admin_password  → web UI login
#  - web.external_url                       → public URL clients see
#                                             (the installer auto-fills
#                                             the IP placeholder in
#                                             external_url with the
#                                             server's primary IP)
#  - backend.awg_mode                       → auto | always | never
#                                             (auto: try amneziawg-go,
#                                             fall back to kernel WG)
#  - database.dsn                           → SQLite file path by default
#
# Everything else is optional and commented below with a short
# description. Uncomment and edit only if you need to override the
# default.
#
# All values can also be set via env: WG_PORTAL_<SECTION>_<KEY>
# (e.g. advanced.log_level → WG_PORTAL_ADVANCED_LOG_LEVEL).
#
# Config is loaded from WG_PORTAL_CONFIG env (systemd unit points to
# /opt/awg-portal/config.yml). If the file is missing, defaults +
# ENV variables are used.
#
# Upstream docs (not everything is compatible with this build):
#   https://github.com/h44z/wg-portal
#   https://wgportal.org (docs for 1.x)
# ──────────────────────────────────────────────────────────────────────

# ============================================================
# Базовые настройки (обязательные)
# ============================================================
core:
  admin_user: admin@example.com
  admin_password: CHANGE_ME_PLEASE   # <-- ОБЯЗАТЕЛЬНО СМЕНИТЕ!
  # restore_state: false             # восстанавливать WG-интерфейсы после перезапуска
  # import_existing: false           # импортировать существующие WG-интерфейсы хоста

# ============================================================
# Расширенные настройки (опционально)
# ============================================================
# advanced:
#   log_level: info                   # debug | info | warn | error
#   config_storage_path: /opt/awg-portal/config  # куда сохранять wg-конфиги (save-config)
#   start_listen_port: 51820          # начальный порт для новых интерфейсов
#   start_cidr_v4: 10.211.1.0/24      # начальная подсеть для пиров

# ============================================================
# Веб-интерфейс
# ============================================================
web:
  # site_title: AWG-PORTAL            # заголовок в браузере
  # listening_address: :8888          # адрес:порт веб-сервера
  external_url: http://<IP>:8888      # <-- installer auto-replaces placeholder above with primary IP

# ============================================================
# AmneziaWG (обфускация трафика)
# ============================================================
# awg_mode: auto — для интерфейсов с обфускацией запускает amneziawg-go
# awg_mode: always — всегда требует AmneziaWG userspace (amneziawg-go)
# awg_mode: never — только WireGuard (kernel), AWG-параметры игнорируются
backend:
  awg_mode: auto                     # auto | always | never

  # Бекенд для управления WG-интерфейсами
  # wgctrl — через WireGuard kernel module (wg set)
  # mikrotik — через RouterOS API
  # pfsense — через pfSense pfctl
  # backend: wgctrl                  # wgctrl | mikrotik | pfsense

# ============================================================
# База данных
# ============================================================
# type — sqlite (по умолчанию) | mysql | postgres | mssql
# dsn  — для sqlite это путь к файлу; для остальных — DSN-строка подключения
database:
  # type: sqlite
  dsn: /opt/awg-portal/data/sqlite.db

# ============================================================
# Prometheus метрики (опционально)
# ============================================================
# metrics:
#   enabled: true
#   listen_address: :8787
