# AWG-PORTAL configuration sample
#
# Все параметры можно задать через переменные окружения:
#   WG_PORTAL_<SECTION>_<KEY>
# Пример: advanced.log_level → WG_PORTAL_ADVANCED_LOG_LEVEL
#
# Конфиг-файл загружается через WG_PORTAL_CONFIG env (systemd: /opt/awg-portal/config.yml)
# Если файл не найден — используются дефолтные значения + ENV-переменные.
#
# Полная документация upstream (не всё совместимо):
#   https://github.com/h44z/wg-portal
#   https://wgportal.org (docs для версии 1.x)

# ============================================================
# Базовые настройки (обязательные)
# ============================================================
core:
  admin_user: admin@example.com
  admin_password: CHANGE_ME_PLEASE   # <-- ОБЯЗАТЕЛЬНО СМЕНИТЕ!
  restore_state: false               # восстанавливать WG-интерфейсы после перезапуска
  import_existing: false             # импортировать существующие WG-интерфейсы хоста

# ============================================================
# Расширенные настройки
# ============================================================
advanced:
  log_level: info                     # debug | info | warn | error
  config_storage_path: /opt/awg-portal/config   # куда сохранять wg-конфиги (save-config)
  start_listen_port: 51820           # начальный порт для интерфейсов
  start_cidr_v4: 10.211.1.0/24       # начальная подсеть для пиров

# ============================================================
# Веб-интерфейс
# ============================================================
web:
  site_title: AWG-PORTAL
  listening_address: :8888
  external_url: http://<IP>:8888      # <-- ЗАМЕНИТЕ на реальный IP/домен

# ============================================================
# AmneziaWG (обфускация трафика)
# ============================================================
# awg_mode: auto — для интерфейсов с обфускацией запускает amneziawg-go
# awg_mode: disabled — только WireGuard (kernel)
# awg_mode: force — только AmneziaWG (userspace)
backend:
  awg_mode: auto                     # auto | disabled | forced

  # Бекенд для управления WG-интерфейсами
  # wgctrl — через WireGuard kernel module (wg set)
  # mikrotik — через RouterOS API
  # pfsense — через pfSense pfctl
  backend: wgctrl                    # wgctrl | mikrotik | pfsense

# ============================================================
# База данных
# ============================================================
database:
  type: sqlite                        # sqlite | mysql | postgres | mssql
  dsn: /opt/awg-portal/data/sqlite.db  # путь к файлу БД или DSN подключения

# ============================================================
# Prometheus метрики (опционально)
# ============================================================
# metrics:
#   enabled: true
#   listen_address: :8787
